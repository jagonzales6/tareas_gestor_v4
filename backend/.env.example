# ==============================================================================
# Gestor de Tareas NIHR v4 — Variables de entorno
# Copia este archivo como .env y rellena los valores reales
# NUNCA incluyas .env en git (ya está en .gitignore)
# ==============================================================================

# --- PostgreSQL (usado también por Docker) ---
POSTGRES_DB=nihr_taskhub
POSTGRES_USER=nihr_user
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASENA_SEGURA

# --- Conexión de la app a la base de datos ---
# Para Docker:          host = nihr-db  (nombre del servicio en docker-compose)
# Para local sin Docker: host = localhost
DATABASE_URL=postgresql://nihr_user:CAMBIA_ESTA_CONTRASENA_SEGURA@nihr-db:5432/nihr_taskhub
DATABASE_SSL=false

# --- Servidor ---
PORT=3000
NODE_ENV=production

# --- Sesión ---
# Genera un valor seguro con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CAMBIA_ESTE_SECRET_POR_ALGO_LARGO_Y_ALEATORIO

# --- CORS ---
# Orígenes permitidos separados por coma (sin barra final).
# Si está vacío, solo se permiten IPs locales (útil en desarrollo).
# Ejemplos:
#   HTTP con IP pública:  ALLOWED_ORIGINS=http://203.0.113.45
#   Dominio con HTTPS:    ALLOWED_ORIGINS=https://tareas.mi-dominio.com
#   Múltiples orígenes:   ALLOWED_ORIGINS=https://tareas.mi-dominio.com,https://otro.com
ALLOWED_ORIGINS=http://TU_IP_O_DOMINIO

# --- HTTPS ---
# Cambiar a true SOLO después de configurar HTTPS con Certbot en nginx.
# Con true: cookie secure=true + sameSite=strict.
# Con false (default): funciona sobre HTTP normal.
HTTPS_ENABLED=false

# --- Google OAuth (opcional) ---
# Registra el proyecto en https://console.cloud.google.com
# La URI de redirección debe coincidir exactamente con lo registrado en Google Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://TU_IP_O_DOMINIO/api/google/callback
