# ==============================================================================
# Gestor de Tareas NIHR v4 — Variables de entorno (SQLite)
# Copia este archivo como .env y rellena los valores reales
# NUNCA incluyas .env en git (ya está en .gitignore)
# ==============================================================================

# --- Base de datos SQLite ---
# Ruta al archivo .db (se crea automáticamente al iniciar)
# Ruta relativa desde backend/ o ruta absoluta
DATABASE_URL=./data/nihr.db

# --- Servidor ---
PORT=3000
NODE_ENV=production

# --- Sesión ---
# Genera un valor seguro con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CAMBIA_ESTE_SECRET_POR_ALGO_LARGO_Y_ALEATORIO

# --- CORS ---
# Orígenes permitidos separados por coma (sin barra final).
# Si está vacío, solo se permiten IPs locales (útil en desarrollo).
# Ejemplos:
#   HTTP con IP local:    ALLOWED_ORIGINS=http://192.168.0.68:3000
#   HTTP con IP pública:  ALLOWED_ORIGINS=http://203.0.113.45
#   Dominio con HTTPS:    ALLOWED_ORIGINS=https://tareas.mi-dominio.com
ALLOWED_ORIGINS=

# --- HTTPS ---
# Cambiar a true SOLO después de configurar HTTPS con Certbot en nginx.
HTTPS_ENABLED=false

# --- Google OAuth (opcional, dejar vacío para ignorar) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
